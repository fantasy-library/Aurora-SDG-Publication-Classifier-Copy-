# Optional. If you already use `.streamlit/secrets.toml` with the same settings, you do
# NOT need a `.env` file.
#
# For Railway, set these as service Variables (environment variables).
# If both TOML and env vars are set, env vars override the mapped keys below.
#
# TOML key                               -> env var
# ---------------------------------------------------------------
# http_user_agent                        -> HTTP_USER_AGENT
# scopus_api_key                         -> SCOPUS_API_KEY
# scopus_insttoken                       -> SCOPUS_INSTTOKEN
# serpapi_api_key                        -> SERPAPI_API_KEY
# google_scholar_enabled                 -> GOOGLE_SCHOLAR_ENABLED
# advanced_options.default_from_date     -> DEFAULT_FROM_DATE

HTTP_USER_AGENT=OpenAlex+Aurora SDG fetcher (mailto:you@example.com)
SCOPUS_API_KEY=
SCOPUS_INSTTOKEN=
SERPAPI_API_KEY=
GOOGLE_SCHOLAR_ENABLED=true
DEFAULT_FROM_DATE=2020-01-01
